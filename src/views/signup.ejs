<!-- Toast -->
<div class="toast" id="toast">
  <i id="toast-icon" class="fas fa-circle-check" style="color:#4ade80;"></i>
  <span id="toast-msg"></span>
</div>

<script>
// ── Particle BG ──
(function() {
  const c = document.getElementById('canvas-bg');
  c.width = window.innerWidth; c.height = window.innerHeight;
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(75, c.width / c.height, 0.1, 1000);
  const renderer = new THREE.WebGLRenderer({ canvas: c, alpha: true, antialias: true });
  renderer.setSize(c.width, c.height); renderer.setClearColor(0, 0);
  camera.position.z = 50;

  const geo = new THREE.BufferGeometry();
  const pos = new Float32Array(900 * 3);
  for (let i = 0; i < pos.length; i++) pos[i] = (Math.random() - 0.5) * 100;
  geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
  const mesh = new THREE.Points(geo, new THREE.PointsMaterial({ size: 0.22, color: 0x8A2BE2, transparent: true, opacity: 0.5 }));
  scene.add(mesh);

  window.addEventListener('resize', () => {
    c.width = window.innerWidth; c.height = window.innerHeight;
    camera.aspect = c.width / c.height; camera.updateProjectionMatrix();
    renderer.setSize(c.width, c.height);
  });

  (function loop() {
    requestAnimationFrame(loop);
    mesh.rotation.x += 0.0003; mesh.rotation.y += 0.0005;
    renderer.render(scene, camera);
  })();
})();

// ── Helpers ──
const isEmail = e => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e);
let toastT;
function toast(msg, err) {
  const el = document.getElementById('toast');
  document.getElementById('toast-msg').textContent = msg;
  document.getElementById('toast-icon').className = err ? 'fas fa-circle-xmark' : 'fas fa-circle-check';
  document.getElementById('toast-icon').style.color = err ? '#f87171' : '#4ade80';
  el.className = 'toast' + (err ? ' err' : '');
  clearTimeout(toastT);
  setTimeout(() => el.classList.add('show'), 10);
  toastT = setTimeout(() => el.classList.remove('show'), 3500);
}

function togglePw(id, icon) {
  const inp = document.getElementById(id);
  inp.type = inp.type === 'password' ? 'text' : 'password';
  icon.classList.toggle('fa-eye'); icon.classList.toggle('fa-eye-slash');
}

// ── Password strength ──
function checkStr(pw) {
  let score = 0;
  if (pw.length >= 8)          score++;
  if (/[A-Z]/.test(pw))        score++;
  if (/[a-z]/.test(pw))        score++;
  if (/[0-9]/.test(pw))        score++;
  if (/[^A-Za-z0-9]/.test(pw)) score++;

  const colors = ['#ef4444','#f97316','#eab308','#4ade80','#22d3ee'];
  const labels = [
    '',
    'Very Weak — use at least 8 characters',
    'Weak — add lowercase and uppercase letters',
    'Fair — add numbers',
    'Good — add special characters',
    'Strong password ✓'
  ];
  const lColors = ['','#f87171','#fb923c','#fbbf24','#4ade80','#22d3ee'];

  for (let i = 1; i <= 5; i++) {
    const fill = document.getElementById(`sf${i}`);
    if (fill) {
      if (i <= score) { fill.style.width = '100%'; fill.style.background = colors[score-1]; }
      else            { fill.style.width = '0'; }
    }
  }
  const lbl = document.getElementById('str-label');
  lbl.textContent = pw.length ? labels[score] : '';
  lbl.style.color = pw.length ? lColors[score] : 'rgba(255,255,255,0.4)';
}

// ── OTP helpers ──
function otpBoxes(prefix) { return document.querySelectorAll(`#${prefix}-otp-wrap .otp-box`); }
function otpIn(el, idx, prefix) {
  el.value = el.value.replace(/\D/g,'').slice(-1);
  el.classList.toggle('filled', !!el.value);
  if (el.value && idx < 5) otpBoxes(prefix)[idx+1].focus();
}
function otpKd(e, idx, prefix) {
  if (e.key === 'Backspace' && !otpBoxes(prefix)[idx].value && idx > 0) otpBoxes(prefix)[idx-1].focus();
}
function otpVal(prefix) { return Array.from(otpBoxes(prefix)).map(b => b.value).join(''); }

// ── Timer ──
// ── Step navigation ──
function goToStep(n) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.getElementById(`panel-${n}`).classList.add('active');
  // Update step indicators
  for (let i = 1; i <= 3; i++) {
    const dot  = document.getElementById(`s${i}`);
    const line = document.getElementById(`l${i}`);
    if (i < n)       { dot.className = 'step-dot done'; dot.innerHTML = '<i class="fas fa-check" style="font-size:0.7rem;"></i>'; }
    else if (i === n){ dot.className = 'step-dot active'; if (i<=3 && dot.textContent !== '✓') dot.textContent = i; }
    else             { dot.className = 'step-dot'; dot.textContent = i; }
    if (line) line.className = i < n ? 'step-line done' : 'step-line';
  }
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ── Step 1: Submit ──
function submitStep1() {
  const fname = document.getElementById('fname').value.trim();
  const lname = document.getElementById('lname').value.trim();
  const email = document.getElementById('email').value.trim();
  const pw    = document.getElementById('password').value;

  if (!fname)          { toast('Please enter your first name.', true);    return; }
  if (!lname)          { toast('Please enter your last name.', true);     return; }
  if (!isEmail(email)) { toast('Please enter a valid email.', true);      return; }
  // Strong password: min 8 chars, upper, lower, number, special
  const strong = pw.length >= 8 && /[A-Z]/.test(pw) && /[a-z]/.test(pw) && /[0-9]/.test(pw) && /[^A-Za-z0-9]/.test(pw);
  if (!strong) {
    toast('Password must be strong: 8+ chars, upper, lower, number, special.', true);
    return;
  }

  // ── API: POST /api/auth/send-otp { name, email, password } ──
  fetch('/api/auth/send-otp', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ name: `${fname} ${lname}`, email, password: pw })
  })
    .then(async res => {
      let data;
      try {
        data = await res.json();
      } catch (err) {
        throw new Error('An unexpected error occurred. Please try again.');
      }
      if (!data.success) throw new Error(data.error || 'Failed to send verification code');
      signupData = { name: `${fname} ${lname}`, email, password: pw };
      document.getElementById('otp-email-show').textContent = email;
      otpBoxes('su').forEach(b => { b.value = ''; b.classList.remove('filled'); });
      goToStep(2);
      startTimer();
      toast(`Verification code sent to ${email}`);
      setTimeout(() => otpBoxes('su')[0].focus(), 300);
    })
    .catch(e => toast(e.message, true));
}

// ── Step 2: Verify OTP ──
function verifyOtp() {
  const code = otpVal('su');
  if (code.length < 6) { toast('Please enter all 6 digits.', true); return; }

  // ── API: POST /api/auth/verify-otp { email, otp: code } ──
  fetch('/api/auth/verify-otp', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email: signupData.email, otp: code })
  })
    .then(async res => {
      let data;
      try {
        data = await res.json();
      } catch (err) {
        throw new Error('An unexpected error occurred. Please try again.');
      }
      if (!data.success) throw new Error(data.error || 'Invalid verification code');
      clearInterval(timerInterval);
      goToStep(3);
      document.getElementById('success-name').textContent = `Signed in as ${signupData.email}`;
      spawnConfetti();
      toast('Account created successfully!');
    })
    .catch(e => toast(e.message, true));
}

// ── Resend ──
function resendCode() {
  // ── API: POST /api/auth/send-otp { email: signupData.email } ──
  otpBoxes('su').forEach(b => { b.value = ''; b.classList.remove('filled'); });
  startTimer();
  toast('A new code has been sent!');
  setTimeout(() => otpBoxes('su')[0].focus(), 200);
}

// ── Google ──
function handleGoogle() {
  // window.location.href = '/auth/google';
  toast('Redirecting to Google…');
}

// ── Confetti ──
function spawnConfetti() {
  const wrap = document.getElementById('confetti-wrap');
  const colors = ['#8A2BE2','#4169E1','#c084fc','#a78bfa','#4ade80','#fbbf24'];
  for (let i = 0; i < 22; i++) {
    const dot = document.createElement('div');
    dot.className = 'confetti-dot';
    dot.style.left    = Math.random() * 100 + '%';
    dot.style.top     = 60 + Math.random() * 20 + '%';
    dot.style.background = colors[Math.floor(Math.random() * colors.length)];
    dot.style.animationDelay = Math.random() * 0.6 + 's';
    dot.style.animationDuration = 1 + Math.random() * 0.8 + 's';
    wrap.appendChild(dot);
    setTimeout(() => dot.remove(), 2000);
  }
}

// ── Enter key ──
document.addEventListener('keydown', e => {
  if (e.key !== 'Enter') return;
  const activePanel = document.querySelector('.panel.active').id;
  if (activePanel === 'panel-1') submitStep1();
  else if (activePanel === 'panel-2') verifyOtp();
});
</script>
