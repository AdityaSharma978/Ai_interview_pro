<script>
// Go back from step 2 to step 1 in forgot password modal
function goBackToForgotEmail() {
  document.getElementById('fp2').style.display = 'none';
  document.getElementById('fp1').style.display = '';
}
// Particle BG
(function() {
  const c = document.getElementById('canvas-right');
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(75, c.offsetWidth / c.offsetHeight, 0.1, 1000);
  const renderer = new THREE.WebGLRenderer({ canvas: c, alpha: true, antialias: true });
  function resize() {
    renderer.setSize(c.offsetWidth, c.offsetHeight);
    camera.aspect = c.offsetWidth / c.offsetHeight;
    camera.updateProjectionMatrix();
  }
  resize(); window.addEventListener('resize', resize);
  renderer.setClearColor(0, 0); camera.position.z = 50;
  const geo = new THREE.BufferGeometry();
  const pos = new Float32Array(700 * 3);
  for (let i = 0; i < pos.length; i++) pos[i] = (Math.random() - 0.5) * 90;
  geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
  const mesh = new THREE.Points(geo, new THREE.PointsMaterial({ size: 0.2, color: 0x8A2BE2, transparent: true, opacity: 0.55 }));
  scene.add(mesh);
  (function loop() { requestAnimationFrame(loop); mesh.rotation.x += 0.0003; mesh.rotation.y += 0.0005; renderer.render(scene, camera); })();
})();

// Helpers
const isEmail = e => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e);
let toastT;
function toast(msg, err) {
  const el = document.getElementById('toast');
  document.getElementById('toast-msg').textContent = msg;
  document.getElementById('toast-icon').className = err ? 'fas fa-circle-xmark' : 'fas fa-circle-check';
  document.getElementById('toast-icon').style.color = err ? '#f87171' : '#4ade80';
  el.className = 'toast' + (err ? ' err' : '');
  clearTimeout(toastT);
  setTimeout(() => el.classList.add('show'), 10);
  toastT = setTimeout(() => el.classList.remove('show'), 3500);
}
function togglePw(id, icon) {
  const inp = document.getElementById(id);
  inp.type = inp.type === 'password' ? 'text' : 'password';
  icon.classList.toggle('fa-eye'); icon.classList.toggle('fa-eye-slash');
}

// OTP
function otpBoxes(prefix) { return document.querySelectorAll(`#${prefix}-otp-wrap .otp-box`); }
function otpIn(el, idx, prefix) {
  el.value = el.value.replace(/\D/g,'').slice(-1);
  el.classList.toggle('filled', !!el.value);
  if (el.value && idx < 5) otpBoxes(prefix)[idx+1].focus();
}
function otpKd(e, idx, prefix) {
  if (e.key === 'Backspace' && !otpBoxes(prefix)[idx].value && idx > 0) otpBoxes(prefix)[idx-1].focus();
}
function otpVal(prefix) { return Array.from(otpBoxes(prefix)).map(b => b.value).join(''); }

// Forgot
function openForgot() { document.getElementById('overlay-forgot').classList.add('open'); }
function closeForgot() {
  document.getElementById('overlay-forgot').classList.remove('open');
  document.getElementById('fp1').style.display = '';
  document.getElementById('fp2').style.display = 'none';
  document.getElementById('fp3').style.display = 'none';
  document.getElementById('fp-email').value = '';
  otpBoxes('fp').forEach(b => { b.value = ''; b.classList.remove('filled'); });
  document.getElementById('fp-newpw').value = '';
  document.getElementById('fp-confirmpw').value = '';
}
function closeForgotBg(e) { if (e.target === document.getElementById('overlay-forgot')) closeForgot(); }

async function fpSend() {
  const email = document.getElementById('fp-email').value.trim();
  if (!isEmail(email)) { toast('Please enter a valid email.', true); return; }
  try {
    const res = await fetch('/api/forgot/send-code', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email })
    });
    let data;
    try {
      data = await res.json();
    } catch (err) {
      throw new Error('An unexpected error occurred. Please try again.');
    }
    if (!data.success) throw new Error(data.error || 'Failed to send code');
    document.getElementById('fp-email-show').textContent = email;
    document.getElementById('fp1').style.display = 'none';
    document.getElementById('fp2').style.display = '';
    toast('Reset code sent to ' + email);
    setTimeout(() => otpBoxes('fp')[0].focus(), 200);
  } catch (e) {
    toast(e.message, true);
  }
}

async function fpReset() {
  const email = document.getElementById('fp-email-show').textContent;
  const code = otpVal('fp');
  const nw = document.getElementById('fp-newpw').value;
  const cf = document.getElementById('fp-confirmpw').value;
  if (code.length < 6)  { toast('Enter all 6 digits.', true); return; }
  if (nw.length < 8)    { toast('Password must be 8+ characters.', true); return; }
  if (nw !== cf)         { toast('Passwords do not match.', true); return; }
  // Verify code first
  try {
    const verify = await fetch('/api/forgot/verify-code', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, code })
    });
    let vdata;
    try {
      vdata = await verify.json();
    } catch (err) {
      throw new Error('An unexpected error occurred. Please try again.');
    }
    if (!vdata.success) throw new Error(vdata.error || 'Invalid code');
    // Now reset password
    const reset = await fetch('/api/forgot/reset', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, code, newPassword: nw })
    });
    let rdata;
    try {
      rdata = await reset.json();
    } catch (err) {
      throw new Error('An unexpected error occurred. Please try again.');
    }
    if (!rdata.success) throw new Error(rdata.error || 'Failed to reset password');
    document.getElementById('fp2').style.display = 'none';
    document.getElementById('fp3').style.display = '';
    toast('Password reset!');
  } catch (e) {
    toast(e.message, true);
  }
}

document.addEventListener('keydown', e => {
  if (e.key !== 'Enter') return;
  if (document.getElementById('overlay-forgot').classList.contains('open')) return;
  handleLogin();
});
